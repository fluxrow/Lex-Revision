# Supabase
# Producao: use um projeto Supabase remoto.
# Nunca aponte Vercel para 127.0.0.1, localhost ou keys do ambiente local.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Docling
# Opcional: URL de um servico dedicado de parsing com Docling.
DOCLING_API_URL=
# Opcional: comando local para desenvolvimento.
# Exemplo: uv run --with docling python3 scripts/docling_extract.py
DOCLING_COMMAND=

# Preview admin
# Use apenas como acesso temporario de validacao quando o Supabase remoto ainda nao estiver configurado.
LEX_PREVIEW_ADMIN_ENABLED=0
LEX_PREVIEW_ADMIN_EMAIL=admin@preview.lex
LEX_PREVIEW_ADMIN_PASSWORD=
LEX_PREVIEW_ADMIN_SECRET=
NEXT_PUBLIC_LEX_PREVIEW_ADMIN_ENABLED=0
NEXT_PUBLIC_LEX_PREVIEW_ADMIN_EMAIL=admin@preview.lex

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_FIRM=price_...

# Clicksign
CLICKSIGN_ACCESS_TOKEN=your_clicksign_access_token
CLICKSIGN_WEBHOOK_SECRET=your_clicksign_webhook_secret

# URL base
NEXT_PUBLIC_APP_URL=http://localhost:3000
